{
  "name": "ancora",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Ancora agent runtime (napi-rs native addon)",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "Apache-2.0",
  "keywords": ["agent", "runtime", "ai", "llm", "napi"],
  "repository": {
    "type": "git",
    "url": "https://github.com/YASSERRMD/Ancora"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "jest",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "napi": {
    "name": "ancora",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
