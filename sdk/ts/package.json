{
  "name": "ancora",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Ancora agent runtime (napi-rs native addon)",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "Apache-2.0",
  "keywords": [
    "agent",
    "runtime",
    "ai",
    "llm",
    "napi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YASSERRMD/Ancora"
  },
  "scripts": {
    "build": "napi build --manifest-path ../../crates/ancora-napi/Cargo.toml --output-dir . --platform --release",
    "build:debug": "napi build --manifest-path ../../crates/ancora-napi/Cargo.toml --output-dir . --platform",
    "build:dts": "tsc --declaration --emitDeclarationOnly --outDir .",
    "build:wasm": "node wasm/esbuild.config.mjs",
    "test": "jest",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "napi": {
    "name": "ancora",
    "triples": {
      "defaults": true
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "@types/jest": "^29.5.0",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.js",
    "*.d.ts",
    "wasm/*.js",
    "wasm/*.d.ts",
    "*.node"
  ],
  "dependencies": {
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@ancora/sdk-linux-x64-gnu": "0.1.0",
    "@ancora/sdk-darwin-x64": "0.1.0",
    "@ancora/sdk-darwin-arm64": "0.1.0",
    "@ancora/sdk-win32-x64-msvc": "0.1.0",
    "@ancora/sdk-linux-arm64-gnu": "0.1.0"
  }
}
